{
	"name": "gds-viewer",
	"version": "0.1.0",
	"description": "3D GDS viewer web component using Three.js",
	"type": "module",
	"main": "dist/gds-viewer.js",
	"module": "dist/gds-viewer.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/gds-viewer.js",
			"default": "./dist/gds-viewer.js"
		}
	},
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "bunx --bun vite",
		"build": "vite build && tsc -p tsconfig.build.json",
		"build:pages": "bunx --bun vite build --config vite.pages.config.ts",
		"prepare": "npm run build",
		"preview": "bunx --bun vite preview",
		"typecheck": "bunx tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"clipper-lib": "^6.4.2",
		"earcut": "^3.0.1",
		"gdsii": "^0.1.0",
		"three": "^0.170.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"@types/three": "^0.170.0",
		"@types/earcut": "^2.1.4"
	},
	"keywords": [
		"gds",
		"gdsii",
		"photonics",
		"semiconductor",
		"viewer",
		"3d",
		"threejs",
		"web-component"
	]
}
